# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# semantic search POC (Milestone 3 Phase 0) — never commit downloaded model weights
/poc/semantic-search/.model-cache/

# embedding generation script's model cache (Milestone 3 Phase 1) — never commit downloaded model weights.
# Note: the generated ARTIFACT itself (public/semantic-search/) IS committed — only the raw model
# weights downloaded to produce it are excluded here.
/.cache/
