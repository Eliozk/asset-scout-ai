# Optional. This app's own public base URL, used only to build canonical
# links, sitemap.xml, and Open Graph metadata — not a secret, not required
# for local dev (falls back to http://localhost:3000). Set it in Vercel once
# the production URL is known, e.g. https://asset-scout-ai.vercel.app
NEXT_PUBLIC_SITE_URL=

# Optional. Sketchfab's public model-search API (v3/search, v3/categories)
# works fully unauthenticated — this app runs and returns live Sketchfab
# results with no token set at all.
#
# Setting a free personal API token (https://sketchfab.com/settings/password
# -> API Tokens, after creating a free Sketchfab account) raises Sketchfab's
# rate limit for your own requests. It is read server-side only
# (src/lib/providers/sketchfab/fetch-assets.ts) and is never sent to the
# browser. Never commit a real token — copy this file to .env.local and put
# the real value there instead.
SKETCHFAB_API_TOKEN=

# Required for the Pixabay provider (unlike Sketchfab's token, this one is
# NOT optional — every Pixabay API request needs a key, or it 401s). Without
# it, Pixabay results are simply omitted from search (Poly Haven, Sketchfab,
# and Kenney are unaffected) and a non-blocking notice explains why.
#
# Get a free key at https://pixabay.com/api/docs/ (requires a free Pixabay
# account — this is NOT created for you; you must sign up yourself). Read
# server-side only (src/lib/providers/pixabay/fetch-assets.ts) and never sent
# to the browser. Never commit a real key — copy this file to .env.local and
# put the real value there instead.
PIXABAY_API_KEY=

# Optional. Enables Gemini-powered multilingual query understanding (e.g. a
# Hebrew request is translated into a validated English SearchIntent before
# searching). Without this key, AssetScout works exactly as it did before —
# the existing local keyword/semantic search path is the fallback, used
# automatically on ANY Gemini failure (missing key, timeout, rate limit,
# quota exhaustion, malformed response, etc.), never an empty page.
#
# Create a free key in Google AI Studio (no billing account, no Cloud project
# setup required): https://aistudio.google.com/apikey
#
# Read server-side only (src/lib/gemini/fetch-intent.ts) and never sent to
# the browser, logged, or included in any error response. On Gemini's free
# ("Unpaid Services") tier, Google's own Additional Terms of Service permit
# using submitted content to improve its products, including human review of
# de-identified input/output — see /legal and README before entering
# anything sensitive. Never commit a real key — copy this file to
# .env.local and put the real value there instead.
GEMINI_API_KEY=

# Optional. Overrides the Gemini model used for query understanding. Defaults
# to gemini-2.5-flash-lite (current stable Gemini Developer API model,
# confirmed free-tier eligible and structured-JSON-output capable — see
# ai.google.dev/gemini-api/docs/models and .../pricing) when unset or blank.
# Only change this to another model explicitly confirmed stable + free-tier +
# structured-output capable.
GEMINI_MODEL=
